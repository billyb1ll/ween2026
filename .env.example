# Baan 7 Main Portal — Environment Variables

# --- Supabase Database Integration ---
# Retrieve these values from your Supabase Project Settings > API dashboard.
VITE_SUPABASE_URL=placeholder
VITE_SUPABASE_ANON_KEY=placeholder

# --- Immich Gallery Integration ---
# Once the DigitalOcean Droplet for the Immich server is provisioned, set this to the production URL.
# e.g., VITE_IMMICH_SERVER_URL=https://gallery.baan7.university.edu
# If left empty, blank, or set to placeholder/todo, the app will fall back gracefully to a "Coming Soon" toast/alert.
VITE_IMMICH_SERVER_URL=placeholder
