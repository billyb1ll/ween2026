# Baan 7 Main Portal — Environment Variables

# --- Supabase API Integration ---
# Retrieve these values from your Supabase Project Settings > API dashboard.
VITE_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# --- Supabase Database Integration (Prisma) ---
# Retrieve these from Supabase Project Settings > Database > Connection String.
# CRITICAL: Due to Supabase migrating to IPv6 natively, you MUST use the IPv4 pooler domains (aws-0-...).
# Transaction Pooler (Port 6543) - Use for standard Prisma Client connectivity
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session Pooler (Port 5432) - Use strictly for database migrations / db push
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Immich Gallery Integration ---
# Ensure you provide the proxying API key for serverless endpoints to bypass CORS and authenticate securely.
VITE_IMMICH_SERVER_URL="https://gallery.baan7.university.edu"
VITE_IMMICH_ALBUM_ID="your-album-id"
IMMICH_VIEWER_API_KEY="your-viewer-key"
IMMICH_API_KEY="your-immich-api-key"
